# 会话 Cookie 名称
UUYP_SESSION_COOKIE_NAME=uuyp_sid

# 会话存活时间（秒），默认 3600（1小时）
UUYP_SESSION_TTL_SECONDS=3600

# 最大并发会话数
UUYP_SESSION_MAX_COUNT=100

# 临时文件清理间隔（秒）
UUYP_CLEANUP_INTERVAL_SECONDS=300

# 临时文件保留时间（秒），超时自动删除
UUYP_ARTIFACT_TTL_SECONDS=1800

# Cookie 安全设置（生产环境启用 HTTPS 时设为 true）
UUYP_COOKIE_SECURE=false
UUYP_COOKIE_SAMESITE=Lax
